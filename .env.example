# ============================================================
# ラーメンクイズ Web アプリ 環境変数テンプレート
# ============================================================
# このファイルをコピーして `.env.local` を作成し、各値を埋めてください。
#   cp .env.example .env.local
#
# 注意:
# - Vite は `VITE_` プレフィックス付き変数のみクライアントバンドルに含めます
# - すべての値はビルド成果物 (JS) に埋め込まれるため、機密情報を入れないこと
#   (Supabase anon キーは公開前提なので可)
# - 本番デプロイ (Vercel) では Vercel Dashboard の Environment Variables に同じ値を登録
# ============================================================


# ---------- Supabase (写真投稿・お問い合わせ・通報機能の有効化) ----------
# 未設定時は写真投稿フォームの送信ボタンが無効化され、ローカルモックで動作します。
# 設定方法は docs/SUPABASE_SETUP.md を参照。
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# 任意。Supabase Storage のバケット名。未指定なら `photo-quiz-user` を使用。
# VITE_SUPABASE_STORAGE_BUCKET=photo-quiz-user


# ---------- Google AdSense (審査通過後に設定) ----------
# 未設定時は広告枠が全てプレースホルダ表示になり、adsbygoogle.js も注入されません。
# 設定方法は docs/ADSENSE_SETUP.md を参照。
#
# パブリッシャー ID (ca-pub- で始まる 19 文字)
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# 各広告ユニットのスロット ID (AdSense 管理画面で広告ユニット作成後に発行される 10 桁の数字)
VITE_ADSENSE_SLOT_HOME_TOP=XXXXXXXXXX
VITE_ADSENSE_SLOT_KNOWLEDGE_TOP=XXXXXXXXXX
VITE_ADSENSE_SLOT_RESULT=XXXXXXXXXX
VITE_ADSENSE_SLOT_FOOTER=XXXXXXXXXX
VITE_ADSENSE_SLOT_IN_FEED=XXXXXXXXXX


# ---------- サイト情報 (OGP・シェア用 URL) ----------
# 本番デプロイ先の絶対 URL。末尾スラッシュなし。
# シェアボタン (X / Facebook 等) で URL 組み立てに使用。
VITE_SITE_URL=https://your-domain.example.com


# ---------- 運営者情報 (プライバシーポリシー・利用規約に表示) ----------
# 未設定時は src/content/legalMeta.ts のデフォルト値が使用されます。
VITE_OPERATOR_NAME=（運営者名 / 個人名 or 屋号）
VITE_OPERATOR_CONTACT=（連絡先メールアドレス）
