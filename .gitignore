# ============================================================
# 切り出し後の公開リポジトリでも安全に動くように設計
# (LifePlanning 親リポジトリの .gitignore を上書きする形でも有効)
# ============================================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Vite / Vercel local
.vercel/

# Cache
.vite/
.turbo/
.cache/

# Env files - .env.example のみコミット、その他は無視
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
!.env.example

# TypeScript build info
*.tsbuildinfo

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Misc
*.local
coverage/
